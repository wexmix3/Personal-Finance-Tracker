# =============================================================
# Database
# =============================================================
DATABASE_URL=postgresql+asyncpg://finance:finance_secret@localhost:5432/finance_db

# Sync URL used only by Alembic (not async)
SYNC_DATABASE_URL=postgresql://finance:finance_secret@localhost:5432/finance_db

# =============================================================
# Auth / Security
# =============================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================
# Plaid
# =============================================================
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
# sandbox | development | production
PLAID_ENV=sandbox
# Comma-separated list of products: transactions,auth,identity
PLAID_PRODUCTS=transactions
# Comma-separated ISO 3166-1 alpha-2 country codes
PLAID_COUNTRY_CODES=US,CA

# =============================================================
# Redis (used by APScheduler job store)
# =============================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================
# App
# =============================================================
# URL of the frontend — used for CORS allow-origins
FRONTEND_URL=http://localhost:3000
# "development" | "production"
ENVIRONMENT=development
